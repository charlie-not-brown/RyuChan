{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "target": "ESNext",
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": {
      "@/*": [
        "src/*"
      ],
      "@components/*": [
        "src/components/*"
      ],
      "@layouts/*": [
        "src/layouts/*"
      ],
      "@config": [
        "src/config.ts"
      ],
      "@interfaces/*": [
        "src/interface/*"
      ],
      "@utils/*": [
        "src/utils/*"
      ]
    },
    "strict": true,
    "esModuleInterop": true
  }
}